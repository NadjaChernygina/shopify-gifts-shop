{% doc %}
  @prompt
    our purtners block, gallery with logos, gallery should smooth autoplay
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-partners-gallery-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-partners-gallery__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.spacing_below_heading }}px;
    padding: 0 20px;
  }

  .ai-partners-gallery__heading-{{ ai_gen_id }} {
    margin: 0 0 10px;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
  }

  .ai-partners-gallery__subheading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.subheading_color }};
    font-size: {{ block.settings.subheading_size }}px;
  }

  .ai-partners-gallery__track-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-partners-gallery__track-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.logo_spacing }}px;
    will-change: transform;
  }

  .ai-partners-gallery__logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.logo_background_color }};
    border-radius: {{ block.settings.logo_border_radius }}px;
    padding: {{ block.settings.logo_padding }}px;
    {% if block.settings.logo_border_thickness > 0 %}
      border: {{ block.settings.logo_border_thickness }}px solid {{ block.settings.logo_border_color }};
    {% endif %}
  }

  .ai-partners-gallery__logo-{{ ai_gen_id }} img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    {% if block.settings.logo_grayscale %}
      filter: grayscale(100%);
      opacity: {{ block.settings.logo_opacity | divided_by: 100.0 }};
      transition: filter 0.3s ease, opacity 0.3s ease;
    {% else %}
      opacity: {{ block.settings.logo_opacity | divided_by: 100.0 }};
    {% endif %}
  }

  {% if block.settings.logo_grayscale %}
    .ai-partners-gallery__logo-{{ ai_gen_id }}:hover img {
      filter: grayscale(0%);
      opacity: 1;
    }
  {% endif %}

  .ai-partners-gallery__logo-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.logo_border_radius }}px;
  }

  .ai-partners-gallery__logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  @media screen and (max-width: 749px) {
    .ai-partners-gallery__logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }
  }
{% endstyle %}

<partners-gallery-{{ ai_gen_id }}
  class="ai-partners-gallery-{{ ai_gen_id }}"
  data-speed="{{ block.settings.scroll_speed }}"
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank or block.settings.subheading != blank %}
    <div class="ai-partners-gallery__header-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-partners-gallery__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}
      {% if block.settings.subheading != blank %}
        <p class="ai-partners-gallery__subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>
  {% endif %}

  <div class="ai-partners-gallery__track-wrapper-{{ ai_gen_id }}">
    <div class="ai-partners-gallery__track-{{ ai_gen_id }}">
      {% for i in (1..12) %}
        {% liquid
          assign logo_key = 'logo_' | append: i
          assign logo = block.settings[logo_key]
          assign url_key = 'logo_' | append: i | append: '_url'
          assign url = block.settings[url_key]
        %}

        {% if logo != blank %}
          <div class="ai-partners-gallery__logo-{{ ai_gen_id }}">
            {% if url != blank %}
              <a href="{{ url }}" target="_blank" rel="noopener">
                <img
                  src="{{ logo | image_url: width: 400 }}"
                  alt="{{ logo.alt | escape }}"
                  loading="lazy"
                  width="{{ block.settings.logo_width }}"
                  height="{{ block.settings.logo_height }}"
                >
              </a>
            {% else %}
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ block.settings.logo_width }}"
                height="{{ block.settings.logo_height }}"
              >
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</partners-gallery-{{ ai_gen_id }}>

<script>
  (function() {
    class PartnersGallery{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-partners-gallery__track-{{ ai_gen_id }}');
        this.speed = parseFloat(this.dataset.speed) || 30;
        this.animationId = null;
        this.position = 0;
      }

      connectedCallback() {
        if (!this.track) return;

        const logos = Array.from(this.track.children);
        if (logos.length === 0) return;

        this.duplicateLogos();
        this.startAnimation();

        this.track.addEventListener('mouseenter', () => this.pauseAnimation());
        this.track.addEventListener('mouseleave', () => this.startAnimation());
      }

      duplicateLogos() {
        const logos = Array.from(this.track.children);
        const clones = logos.map(logo => logo.cloneNode(true));
        clones.forEach(clone => this.track.appendChild(clone));

        const secondClones = logos.map(logo => logo.cloneNode(true));
        secondClones.forEach(clone => this.track.appendChild(clone));
      }

      startAnimation() {
        if (this.animationId) return;

        const logos = Array.from(this.track.children);
        if (logos.length === 0) return;

        const firstLogoWidth = logos[0].offsetWidth;
        const gap = parseInt(getComputedStyle(this.track).gap) || 0;
        const totalWidth = firstLogoWidth + gap;
        const originalLogosCount = logos.length / 3;
        const resetPoint = totalWidth * originalLogosCount;

        const animate = () => {
          this.position += this.speed / 60;

          if (this.position >= resetPoint) {
            this.position = 0;
          }

          this.track.style.transform = `translateX(-${this.position}px)`;
          this.animationId = requestAnimationFrame(animate);
        };

        this.animationId = requestAnimationFrame(animate);
      }

      pauseAnimation() {
        if (this.animationId) {
          cancelAnimationFrame(this.animationId);
          this.animationId = null;
        }
      }

      disconnectedCallback() {
        this.pauseAnimation();
      }
    }

    customElements.define('partners-gallery-{{ ai_gen_id }}', PartnersGallery{{ ai_gen_id }});
  })();
</script>

